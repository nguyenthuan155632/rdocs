{
  "name": "opendocuments-core",
  "version": "0.3.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && npm run copy-sql",
    "copy-sql": "node -e \"const fs=require('fs'),p=require('path'),d='dist/storage/migrations';fs.mkdirSync(d,{recursive:true});fs.readdirSync('src/storage/migrations').filter(f=>f.endsWith('.sql')).forEach(f=>fs.copyFileSync(p.join('src/storage/migrations',f),p.join(d,f)))\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.27.1",
    "better-sqlite3": "^11.0.0",
    "chalk": "^5.3.0",
    "eventemitter3": "^5.0.0",
    "jiti": "^2.6.1",
    "js-tiktoken": "^1.0.21",
    "semver": "^7.7.4",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/semver": "^7.7.1",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  },
  "description": "Core RAG engine for OpenDocuments, including ingestion, hybrid retrieval, storage, auth, security, and plugins",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/joungminsung/OpenDocuments.git",
    "directory": "packages/core"
  },
  "keywords": [
    "opendocuments",
    "rag",
    "retrieval-augmented-generation",
    "ai",
    "llm",
    "document-search",
    "knowledge-base",
    "self-hosted",
    "vector-search",
    "hybrid-search",
    "embeddings",
    "lancedb",
    "sqlite",
    "typescript"
  ],
  "files": [
    "dist/**/*"
  ],
  "homepage": "https://github.com/joungminsung/OpenDocuments#readme",
  "bugs": {
    "url": "https://github.com/joungminsung/OpenDocuments/issues"
  },
  "author": "OpenDocuments Contributors"
}
